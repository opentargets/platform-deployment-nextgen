{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "type": "object",
  "title": "Platform Apps Helm Chart Values Schema",
  "description": "Schema for OpenTargets platform Helm chart values",
  "properties": {
    "gcpProject": {
      "type": "string",
      "description": "The Google Cloud Project ID where the cluster lives."
    },
    "prefix": {
      "type": "string",
      "description": "The prefix for all resources. Identifies the deployment slot (e.g., `production-blue`, `devcluster-green`)."
    },
    "product": {
      "type": "string",
      "enum": ["platform", "ppp"],
      "description": "The product name: either `platform` or `ppp`. Affects domain names, resource allocation, and configuration."
    },
    "domain": {
      "type": "string",
      "description": "The domain name where the application will be exposed."
    },
    "subdomainPrefix": {
      "type": "string",
      "description": "Subdomain prefix e.g. staging"
    },
    "dnsZone": {
      "type": "string",
      "description": "The Google Cloud DNS zone name where the domain is managed."
    },
    "googleTagManagerId": {
      "type": "string",
      "description": "The Google Tag Manager ID for the production WebApp (format: `GTM-XXXXXX`).",
      "pattern": "^GTM-[A-Z0-9]+$"
    },
    "gcp": {
      "type": "object",
      "description": "GCP-specific feature flags.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "When false, skips GCP-native resources (Config Connector, ManagedCertificate, SecretProviderClass, VolumeSnapshot) for local testing."
        },
        "ingress": {
          "type": "boolean"
        }
      },
      "required": ["enabled"],
      "additionalProperties": false
    },
    "release": {
      "type": "string",
      "description": "The data release name (e.g., `25.09`).",
      "pattern": "^\\d{2}\\.\\d{2}(-.*)?$"
    },
    "webapp": {
      "$ref": "#/$defs/webappService"
    },
    "api": {
      "$ref": "#/$defs/apiService"
    },
    "aiapi": {
      "$ref": "#/$defs/aiapiService"
    },
    "clickhouse": {
      "$ref": "#/$defs/clickhouseConfig"
    },
    "opensearch": {
      "$ref": "#/$defs/opensearchConfig"
    },
    "resources": {
      "type": "object",
      "description": "Resource allocations for each component.",
      "properties": {
        "webapp": {
          "$ref": "#/$defs/serviceResources"
        },
        "api": {
          "$ref": "#/$defs/serviceResources"
        },
        "aiapi": {
          "$ref": "#/$defs/serviceResources"
        },
        "clickhouse": {
          "$ref": "#/$defs/clickhouseResources"
        },
        "opensearch": {
          "$ref": "#/$defs/opensearchResources"
        }
      },
      "required": ["webapp", "api", "aiapi", "clickhouse", "opensearch"],
      "additionalProperties": false
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets for pods to authenticate with private registries.",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        },
        "required": ["name"]
      }
    },
    "security": {
      "type": "object",
      "description": "API security blacklists and whitelists.",
      "properties": {
        "rateLimiterWhitelist": {
          "type": "array",
          "description": "CIDR blocks exempt from API rate limiting.",
          "items": {
            "type": "string"
          }
        },
        "blacklist": {
          "type": "array",
          "description": "CIDR blocks blocked from accessing the API.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["rateLimiterWhitelist", "blacklist"],
      "additionalProperties": false
    }
  },
  "required": [
    "gcpProject",
    "prefix",
    "product",
    "domain",
    "dnsZone",
    "googleTagManagerId",
    "gcp",
    "release",
    "webapp",
    "api",
    "aiapi",
    "clickhouse",
    "opensearch",
    "resources"
  ],
  "additionalProperties": false,
  "$defs": {
    "clickhouseConfig": {
      "type": "object",
      "description": "ClickHouse release configuration.",
      "properties": {
        "snapshot": {
          "type": "string",
          "description": "GCP snapshot path to restore ClickHouse data from. Empty string skips snapshot init (for local testing)."
        },
        "image": {
          "$ref": "#/$defs/imageConfig"
        }
      },
      "required": ["snapshot", "image"],
      "additionalProperties": false
    },
    "opensearchConfig": {
      "type": "object",
      "description": "OpenSearch release configuration.",
      "properties": {
        "snapshot": {
          "type": "string",
          "description": "GCP snapshot path to restore OpenSearch data from. Empty string skips snapshot init (for local testing)."
        },
        "image": {
          "$ref": "#/$defs/imageConfig"
        }
      },
      "required": ["snapshot", "image"],
      "additionalProperties": false
    },
    "clickhouseResources": {
      "type": "object",
      "description": "ClickHouse infrastructure sizing.",
      "properties": {
        "replicas": {
          "type": "integer",
          "minimum": 1
        },
        "storageSize": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d+)?(Mi|Gi|Ti)$"
        },
        "requests": {
          "$ref": "#/$defs/resourceRequirements"
        },
        "limits": {
          "$ref": "#/$defs/resourceLimits"
        }
      },
      "required": ["replicas", "storageSize", "requests", "limits"],
      "additionalProperties": false
    },
    "opensearchResources": {
      "type": "object",
      "description": "OpenSearch infrastructure sizing.",
      "properties": {
        "replicas": {
          "type": "integer",
          "minimum": 1
        },
        "storageSize": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d+)?(Mi|Gi|Ti)$"
        },
        "heapSize": {
          "type": "string",
          "description": "JVM heap size (e.g., 8g, 512m)."
        },
        "requests": {
          "$ref": "#/$defs/resourceRequirements"
        },
        "limits": {
          "$ref": "#/$defs/resourceLimits"
        }
      },
      "required": ["replicas", "storageSize", "heapSize", "requests", "limits"],
      "additionalProperties": false
    },
    "webappService": {
      "type": "object",
      "properties": {
        "image": {
          "$ref": "#/$defs/imageConfig"
        }
      },
      "required": ["image"],
      "additionalProperties": false
    },
    "apiService": {
      "type": "object",
      "properties": {
        "image": {
          "$ref": "#/$defs/imageConfig"
        }
      },
      "required": ["image"],
      "additionalProperties": false
    },
    "aiapiService": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to deploy the AI API. Set to false to skip the deployment entirely (e.g., for local testing)."
        },
        "image": {
          "$ref": "#/$defs/imageConfig"
        },
        "secrets": {
          "type": "object",
          "description": "Secrets for the AI API.",
          "properties": {
            "openai": {
              "type": "string",
              "description": "On GCP: full Secret Manager resource path. Locally: the token value itself (or empty string to skip)."
            }
          },
          "additionalProperties": false
        }
      },
      "required": ["image", "secrets"],
      "additionalProperties": false
    },
    "imageConfig": {
      "type": "string",
      "description": "Full container image reference including tag (e.g., `gcr.io/project/image:tag`)."
    },
    "serviceResources": {
      "type": "object",
      "properties": {
        "minReplicas": {
          "type": "integer",
          "minimum": 0
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "requests": {
          "$ref": "#/$defs/resourceRequirements"
        },
        "limits": {
          "$ref": "#/$defs/resourceLimits"
        }
      },
      "required": ["minReplicas", "maxReplicas", "requests", "limits"],
      "additionalProperties": false
    },
    "resourceRequirements": {
      "type": "object",
      "properties": {
        "memory": {
          "pattern": "^\\d+(\\.\\d+)?(Mi|Gi|Ki|m)?$"
        },
        "cpu": {
          "pattern": "^\\d+(\\.\\d+)?(m)?$"
        }
      },
      "required": ["memory", "cpu"],
      "additionalProperties": false
    },
    "resourceLimits": {
      "type": "object",
      "properties": {
        "memory": {
          "pattern": "^\\d+(\\.\\d+)?(Mi|Gi|Ki|m)?$"
        },
        "cpu": {
          "pattern": "^\\d+(\\.\\d+)?(m)?$"
        }
      },
      "required": ["memory", "cpu"],
      "additionalProperties": false
    }
  }
}
