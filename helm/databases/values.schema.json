{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "type": "object",
  "title": "Databases Helm Chart Values Schema",
  "description": "Schema for the OpenTargets in-cluster databases Helm chart (ClickHouse).",
  "required": [
    "gcpProject",
    "prefix",
    "disk",
    "clickhouse"
  ],
  "additionalProperties": false,
  "$defs": {
    "nodeCommon": {
      "type": "object",
      "required": [
        "snapshot",
        "replicas",
        "version",
        "storageSize",
        "resources"
      ],
      "additionalProperties": false,
      "properties": {
        "snapshot": {
          "description": "Snapshot configuration or identifier.",
          "type": [
            "string",
            "object",
            "null"
          ]
        },
        "replicas": {
          "type": "integer",
          "description": "Number of replicas.",
          "minimum": 1
        },
        "version": {
          "type": "string",
          "description": "Image tag (e.g. `25.8.2.29` or `2.11.1`)."
        },
        "storageSize": {
          "type": "string",
          "description": "Size of the data PVC (e.g. `100Gi`). Must be a valid Kubernetes storage quantity.",
          "pattern": "^[0-9]+(Ki|Mi|Gi|Ti|Pi|Ei|m|k|M|G|T|P|E)?$"
        },
        "resources": {
          "type": "object",
          "description": "CPU and memory resource requests and limits.",
          "required": [
            "requests",
            "limits"
          ],
          "additionalProperties": false,
          "properties": {
            "requests": {
              "type": "object",
              "description": "Minimum resource requests.",
              "required": [
                "cpu",
                "memory"
              ],
              "additionalProperties": false,
              "properties": {
                "cpu": {
                  "type": "string",
                  "description": "CPU request (e.g. `1000m`).",
                  "pattern": "^[0-9]+(m)?$"
                },
                "memory": {
                  "type": "string",
                  "description": "Memory request (e.g. `2Gi`).",
                  "pattern": "^[0-9]+(Ki|Mi|Gi|Ti|Pi|Ei|k|M|G|T|P|E)?$"
                }
              }
            },
            "limits": {
              "type": "object",
              "description": "Maximum resource limits.",
              "required": [
                "cpu",
                "memory"
              ],
              "additionalProperties": false,
              "properties": {
                "cpu": {
                  "type": "string",
                  "description": "CPU limit (e.g. `16000m`).",
                  "pattern": "^[0-9]+(m)?$"
                },
                "memory": {
                  "type": "string",
                  "description": "Memory limit (e.g. `60Gi`).",
                  "pattern": "^[0-9]+(Ki|Mi|Gi|Ti|Pi|Ei|k|M|G|T|P|E)?$"
                }
              }
            }
          }
        }
      }
    },
    "clickhouseNode": {
      "allOf": [
        {
          "$ref": "#/$defs/nodeCommon"
        },
        {
          "properties": {
            "version": {
              "description": "ClickHouse image tag (e.g. `25.8.2.29`)."
            }
          }
        }
      ]
    }
  },
  "properties": {
    "gcpProject": {
      "type": "string",
      "description": "The Google Cloud Project ID where the cluster lives.",
      "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$"
    },
    "prefix": {
      "type": "string",
      "description": "Environment prefix used to name the platform/ppp namespaces (e.g. `devcluster`, `production`).",
      "minLength": 1
    },
    "disk": {
      "type": "object",
      "description": "Provisioned disk settings for the hyperdisk-balanced StorageClass.",
      "required": [
        "iops",
        "throughput"
      ],
      "additionalProperties": false,
      "properties": {
        "iops": {
          "type": "string",
          "description": "Provisioned IOPS on create (e.g. `3000`).",
          "pattern": "^[0-9]+$"
        },
        "throughput": {
          "type": "string",
          "description": "Provisioned MiB/s throughput on create (e.g. `140Mi`).",
          "pattern": "^[0-9]+(Mi|Gi)?$"
        }
      }
    },
    "clickhouse": {
      "$ref": "#/$defs/clickhouseNode",
      "description": "ClickHouse configuration (flat, not nested)."
    }
  }
}
